# Pronote Automation — Configuration Template
# Copy this file to config.yaml and fill in your values.
# config.yaml is excluded from git.

pronote:
  # Full base URL of your Pronote instance (trailing slash required)
  baseUrl: "https://2170001x.index-education.net/pronote/"
  # Login portal: PARENT or STUDENT
  loginMode: PARENT
  # Pronote username
  username: "your_username"
  # Pronote password (or set env var PRONOTE_PASSWORD to avoid storing it here)
  password: "your_password"
  # How many weeks back to fetch assignments (0 = current week only)
  weeksBefore: 0
  # How many weeks ahead to fetch assignments
  weeksAhead: 2
  # Optional: class group filter. Only timetable entries belonging to this group are kept.
  # Class group filter. When set, only entries whose G=2 label in ListeContenus matches this
  # string (case-insensitive substring) are kept; entries with no G=2 label (whole-class) are
  # always included regardless. Leave blank (default) to disable — recommended when using a
  # parent account with childId set, because the ressource param already scopes results to the
  # specific child and Pronote does not return entries for parallel groups the child is not in.
  # Use only if you observe duplicate entries for both halves of a subject-group split.
  # group: "6C SIA G1"

data:
  # Directory for snapshots, session, and lockout files
  directory: "./data"
  # Number of days to keep archived snapshots
  archiveRetainDays: 30

safety:
  # Minimum delay between HTTP requests (milliseconds)
  minDelayMs: 2000
  # Maximum random jitter added to delay (milliseconds)
  jitterMs: 500
  # Abort and lock out after this many consecutive login failures
  maxLoginFailures: 3

notifications:
  # Both channels can be left disabled during initial setup.
  # The diff result is always written to data/diff-latest.json and data/diff-history.log
  # regardless of notification settings.

  ntfy:
    enabled: false
    # ntfy server URL (use https://ntfy.sh for the public instance, or self-host)
    serverUrl: "https://ntfy.sh"
    # Topic name — keep this hard-to-guess if using the public server
    topic: "your-secret-topic-name"
    # Bearer token (optional, for protected topics)
    # token: "your-ntfy-token"

  email:
    enabled: false
    smtpHost: "smtp.gmail.com"
    smtpPort: 587
    # SMTP username (often your email address)
    username: "you@gmail.com"
    # SMTP password or App Password (for Gmail with 2FA)
    password: "your_app_password"
    from: "you@gmail.com"
    to: "recipient@example.com"

timetableView:
  # Generate static HTML pages for the upcoming N weekdays after each timetable fetch.
  # Files are written to outputDirectory: one YYYY-MM-DD.html per day, plus index.html.
  enabled: true
  # Output directory. Use "./docs/timetable" to publish via GitHub Pages.
  outputDirectory: "./data/views/timetable"
  # Number of upcoming weekdays (Mon–Fri) to generate, starting from today.
  daysAhead: 5

assignmentView:
  # Generate a single static HTML page listing all upcoming assignments (dueDate >= today)
  # after each successful assignments fetch. Assignments are grouped by due date then subject.
  # Local attachments (downloaded files) are linked via relative paths; hyperlinks are linked
  # to their external URL. The page is responsive and print-friendly.
  enabled: true
  # Output directory for the generated index.html.
  outputDirectory: "./data/views/assignments"

viewPublish:
  # Publish generated view files to a local GitHub Pages repository clone.
  # When enabled, timetable and assignment HTML files are copied into the repo,
  # staged, committed (only when changes exist), and pushed after each views run.
  enabled: false
  # Absolute path to the local git clone of your GitHub Pages repository.
  repoPath: "/home/pi/github-pages-repo"
  # Subdirectory inside the repo where view files are written.
  # Timetable files go to <repoPath>/<targetSubdir>/timetable/
  # Assignment files go to <repoPath>/<targetSubdir>/assignments/
  targetSubdir: "pronote"
  # Commit message when changes are detected.
  commitMessage: "Update Pronote views"
  # Number of push retries after a non-fast-forward rejection.
  # Each retry is preceded by `git pull --rebase` to incorporate remote commits.
  pushRetries: 3
  # Copy downloaded assignment attachments (G=1 uploaded files) into the repo so they
  # are accessible via GitHub Pages. Files are placed at a path that preserves the relative
  # hrefs already embedded in assignments/index.html — no link rewriting needed.
  # They land at: <repoPath>/snapshots/assignments/attachments/<id>/<file>
  # Existing attachment files are overwritten but never deleted (accumulate over time).
  publishAttachments: true

# Subject enrichment — controls the enrichedSubject field on all persisted data types.
# Rules with both subject + teacher are matched first (most specific).
# Rules with subject only apply to any teacher (and to data types without a teacher, e.g. assignments).
# When no rule matches, enrichedSubject falls back to the original subject string.
subjectEnrichment:
  # Some Pronote API endpoints return teacher names prefixed with a civil title:
  #   evaluations (DernieresEvaluations) → "M. DUPONT J." / "Mme MARTIN S."
  #   timetable (PageEmploiDuTemps)      → "DUPONT J."  (no prefix)
  # List the prefixes here; they are stripped before rule matching so a single rule covers
  # both forms (timetable with no prefix, evaluations with prefix).
  # Matching: "M." strips "M. DUPONT J." → "DUPONT J." (prefix + space removed from start).
  teacherPrefixes:
    - "M."
    - "Mme"
  rules:
    # Example: disambiguate HISTOIRE-GEOGRAPHIE by teacher (one rule per teacher)
    # The bare teacher name ("DUPONT J.") works for both timetable and evaluations thanks
    # to teacherPrefixes above — no need to duplicate rules with "M. DUPONT J.".
    - subject: "HISTOIRE-GEOGRAPHIE"
      teacher: "DUPONT J."
      enrichedSubject: "Histoire"
    - subject: "HISTOIRE-GEOGRAPHIE"
      teacher: "MARTIN S."
      enrichedSubject: "Géographie"
    # Subject-only rules (no teacher) — apply to all data types including assignments
    - subject: "MATHEMATIQUES"
      enrichedSubject: "Mathématiques"
    - subject: "FRANCAIS"
      enrichedSubject: "Français"
